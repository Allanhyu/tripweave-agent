# Backend server
HOST=127.0.0.1
PORT=8010
RELOAD=false
CORS_ORIGINS=http://127.0.0.1:5190,http://localhost:5190

# OpenAI-compatible LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=gpt-4o-mini
LLM_TIMEOUT=120
LLM_RESPONSE_FORMAT=json_object

# AMap Web Service and JS API
AMAP_WEB_SERVICE_KEY=
AMAP_WEB_JS_KEY=
AMAP_SECURITY_JS_CODE=
AMAP_SIG_PRIVATE_KEY=

# OpenWeather 5 day / 3 hour forecast
OPENWEATHER_API_KEY=
OPENWEATHER_API_HOST=https://api.openweathermap.org

# Tavily public travel research
TAVILY_API_KEY=
TAVILY_API_HOST=https://api.tavily.com
TAVILY_INCLUDE_DOMAINS=
